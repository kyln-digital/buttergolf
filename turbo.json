{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "db:generate"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", ".expo/**", "!.expo/web/**"],
      "env": [
        "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
        "NEXT_PUBLIC_CLERK_PROXY_URL",
        "CLERK_SECRET_KEY",
        "CLERK_WEBHOOK_SECRET",
        "DATABASE_URL",
        "POSTGRES_URL",
        "POSTGRES_PRISMA_URL",
        "POSTGRES_URL_NO_SSL",
        "POSTGRES_URL_NON_POOLING",
        "POSTGRES_USER",
        "POSTGRES_HOST",
        "POSTGRES_PASSWORD",
        "POSTGRES_DATABASE",
        "DATABASE_URL_UNPOOLED",
        "PGHOST",
        "PGHOST_UNPOOLED",
        "PGUSER",
        "PGPASSWORD",
        "PGDATABASE",
        "NEON_PROJECT_ID",
        "STRIPE_SECRET_KEY",
        "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY",
        "STRIPE_WEBHOOK_SECRET",
        "STRIPE_CONNECT_WEBHOOK_SECRET",
        "BLOB_READ_WRITE_TOKEN",
        "SHIPENGINE_API_KEY",
        "SHIPENGINE_WEBHOOK_SECRET",
        "RESEND_API_KEY",
        "CLOUDINARY_API_KEY",
        "CLOUDINARY_API_SECRET",
        "NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME",
        "MOBILE_SESSION_SECRET",
        "SENTRY_AUTH_TOKEN",
        "TAMAGUI_DEBUG",
        "TAMAGUI_DISABLE_MISSING_TOKEN_LOG",
        "NODE_ENV",
        "SITE_URL",
        "APP_URL",
        "NEXT_PUBLIC_APP_URL",
        "NEXT_PUBLIC_BASE_URL",
        "NEXT_PUBLIC_COMING_SOON_ENABLED",
        "NEXT_PUBLIC_APP_STORE_URL",
        "NEXT_PUBLIC_PLAY_STORE_URL",
        "ANALYZE",
        "DISABLE_EXTRACTION",
        "CI",
        "REDIS_URL",
        "SUPABASE_SERVICE_ROLE_KEY",
        "VERCEL_URL",
        "CRON_SECRET",
        "ADMIN_USER_IDS",
        "ALLOWED_ORIGINS",
        "NEXT_RUNTIME"
      ]
    },
    "db:generate": {
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "db:migrate:dev": {
      "cache": false
    },
    "db:migrate:deploy": {
      "cache": false
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    },
    "db:seed": {
      "cache": false
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "test": {
      "dependsOn": ["^build", "db:generate"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    }
  }
}
