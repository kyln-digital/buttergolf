{
  "name": "buttergolf",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=web",
    "dev:mobile": "turbo run dev --filter=mobile",
    "dev:mobile:ios": "pnpm --filter mobile run ios",
    "dev:mobile:android": "pnpm --filter mobile run android",
    "build-ios": "pnpm --filter mobile run ios:local:build-and-submit:auto",
    "ios:local:build-and-submit": "pnpm --filter mobile run ios:local:build-and-submit",
    "db:generate": "turbo run db:generate",
    "db:push": "turbo run db:push",
    "db:migrate:dev": "turbo run db:migrate:dev",
    "db:migrate:deploy": "turbo run db:migrate:deploy",
    "db:studio": "turbo run db:studio",
    "db:seed": "turbo run db:seed",
    "upload:images": "tsx scripts/upload-sample-images.ts",
    "optimize:site-images": "tsx scripts/optimize-site-images.ts",
    "optimize:site-images:dry-run": "tsx scripts/optimize-site-images.ts --dry-run",
    "reset-stripe": "tsx scripts/reset-stripe-onboarding.ts",
    "lint": "turbo run lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "typecheck": "turbo run check-types",
    "check-types": "turbo run check-types",
    "check": "pnpm format && pnpm lint && pnpm check-types",
    "check-deps": "check-dependency-version-consistency .",
    "clean": "turbo run clean && rm -rf node_modules",
    "clean-install": "pnpm clean && pnpm install",
    "lighthouse": "node scripts/lighthouse.js"
  },
  "devDependencies": {
    "@tamagui/cli": "catalog:",
    "check-dependency-version-consistency": "^5.0.1",
    "dotenv": "^17.2.3",
    "eslint": "catalog:",
    "eslint-plugin-turbo": "^2.7.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.6.2",
    "tsx": "catalog:",
    "turbo": "^2.7.3",
    "typescript": "catalog:",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "react-is": "19.1.0",
      "@types/react": "19.2.14",
      "@types/react-dom": "19.1.0",
      "jsdom": "false",
      "webidl-conversions": "5.0.0",
      "react-native": "0.81.5",
      "react-native-svg": "15.12.1",
      "react-native-reanimated": "4.1.1",
      "expo-constants": "18.0.13",
      "simple-git": "3.36.0",
      "shell-quote": "1.9.0",
      "@babel/core@7": "7.29.6",
      "@opentelemetry/core@2": "2.8.0",
      "@xmldom/xmldom@0.8": "0.8.13",
      "ajv@8": "8.18.0",
      "brace-expansion@1": "1.1.13",
      "brace-expansion@2": "2.0.3",
      "brace-expansion@5": "5.0.6",
      "defu@6": "6.1.5",
      "effect@3": "3.20.0",
      "fast-uri@3": "3.1.2",
      "flatted@3": "3.4.2",
      "form-data@4": "4.0.6",
      "js-cookie@3": "3.0.7",
      "js-yaml@3": "3.15.0",
      "lodash@4": "4.18.0",
      "minimatch@10": "10.2.3",
      "minimatch@3": "3.1.4",
      "minimatch@5": "5.1.8",
      "minimatch@8": "8.0.6",
      "minimatch@9": "9.0.7",
      "node-forge@1": "1.4.0",
      "path-to-regexp@0.1": "0.1.13",
      "picomatch@2": "2.3.2",
      "picomatch@3": "3.0.2",
      "picomatch@4": "4.0.4",
      "piscina@4": "4.9.3",
      "postcss@8": "8.5.16",
      "qs@6": "6.15.2",
      "rollup@4": "4.59.0",
      "serialize-javascript@6": "6.0.2",
      "svgo@3": "3.3.3",
      "svgo@4": "4.0.1",
      "tar@7": "7.5.16",
      "undici@6": "6.27.0",
      "vite@7": "7.3.5",
      "ws@6": "6.2.4",
      "ws@7": "7.5.11",
      "ws@8": "8.21.0",
      "yaml@1": "1.10.3"
    },
    "ignoredBuiltDependencies": [
      "@clerk/shared",
      "@parcel/watcher",
      "@prisma/client",
      "bufferutil",
      "nodent-runtime",
      "utf-8-validate"
    ],
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "@sentry/cli",
      "browser-tabs-lock",
      "core-js",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  },
  "packageManager": "pnpm@10.30.2",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@types/react": "19.2.14"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,md}": [
      "pnpm exec prettier --write"
    ],
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "pnpm exec eslint --fix"
    ]
  }
}
