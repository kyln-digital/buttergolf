{
  "name": "buttergolf",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=web",
    "dev:mobile": "turbo run dev --filter=mobile",
    "dev:mobile:ios": "pnpm --filter mobile run ios",
    "dev:mobile:android": "pnpm --filter mobile run android",
    "db:generate": "turbo run db:generate",
    "db:push": "turbo run db:push",
    "db:migrate:dev": "turbo run db:migrate:dev",
    "db:migrate:deploy": "turbo run db:migrate:deploy",
    "db:studio": "turbo run db:studio",
    "db:seed": "turbo run db:seed",
    "upload:images": "tsx scripts/upload-sample-images.ts",
    "reset-stripe": "tsx scripts/reset-stripe-onboarding.ts",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "check-deps": "check-dependency-version-consistency .",
    "clean": "turbo run clean && rm -rf node_modules",
    "clean-install": "pnpm clean && pnpm install",
    "lighthouse": "node scripts/lighthouse.js"
  },
  "devDependencies": {
    "@tamagui/cli": "catalog:",
    "check-dependency-version-consistency": "^5.0.1",
    "dotenv": "^17.2.3",
    "eslint": "catalog:",
    "eslint-plugin-turbo": "^2.7.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.6.2",
    "tsx": "catalog:",
    "turbo": "^2.7.3",
    "typescript": "catalog:"
  },
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "react-is": "19.1.0",
      "@types/react": "19.1.17",
      "@types/react-dom": "19.1.0",
      "jsdom": "false",
      "webidl-conversions": "5.0.0",
      "react-native": "0.81.5",
      "react-native-svg": "15.12.1",
      "react-native-reanimated": "4.1.1",
      "expo-constants": "18.0.13"
    },
    "ignoredBuiltDependencies": [
      "@clerk/shared",
      "@parcel/watcher",
      "bufferutil",
      "nodent-runtime",
      "utf-8-validate"
    ],
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "@sentry/cli",
      "browser-tabs-lock",
      "core-js",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  },
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@types/react": "19.1.17"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,md,yaml,yml}": [
      "pnpm exec prettier --write"
    ],
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "pnpm exec eslint --fix"
    ]
  }
}
