# Web (Next.js)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Clerk Proxy URL - only set for production where clerk.buttergolf.com is configured
# Leave empty/unset for local dev and Vercel preview deployments
# Production: /__clerk
NEXT_PUBLIC_CLERK_PROXY_URL=

# Coming Soon Mode
# Set to "true" to redirect all traffic to the Coming Soon page
# Useful for pre-launch production deployments
NEXT_PUBLIC_COMING_SOON_ENABLED=false

# Site URL for SEO (sitemap generation, structured data)
# Development: http://localhost:3000
# Production: https://www.buttergolf.com
SITE_URL=http://localhost:3000

# Cloudinary (Image Uploads & CDN)
# Sign up at https://cloudinary.com to get these credentials
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Stripe Payment Processing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Separate webhook secret for Stripe Connect events (falls back to STRIPE_WEBHOOK_SECRET)
STRIPE_CONNECT_WEBHOOK_SECRET=

# REQUIRED: signs short-lived mobile session tokens (min 32 random characters).
# The app refuses to mint/verify mobile session tokens without it.
MOBILE_SESSION_SECRET=

# Bearer token protecting the Vercel cron endpoints (release-payments, payment-reminders, expire-offers)
CRON_SECRET=

# Comma-separated Clerk user IDs allowed to bypass the coming-soon redirect
ADMIN_USER_IDS=

# Comma-separated origins allowed for CORS on /api/upload
ALLOWED_ORIGINS=

# Resend (transactional email)
RESEND_API_KEY=

# ShipEngine webhook signature secret (webhooks rejected without it)
SHIPENGINE_WEBHOOK_SECRET=

# ShipEngine Shipping API (UK)
# Sign up at https://www.shipengine.com/signup/?code=shipengine_free_uk
# Supports Royal Mail, Evri (Hermes), DPD, and more UK carriers
SHIPENGINE_API_KEY=

# Mobile (Expo)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Required for iOS Apple Pay with Stripe native SDK.
# Default in code: merchant.com.buttergolf.app
EXPO_PUBLIC_STRIPE_MERCHANT_IDENTIFIER=

# API URL for mobile app to connect to Next.js backend
# Development - iOS Simulator:
#   EXPO_PUBLIC_API_URL=http://localhost:3000
# Development - Android Emulator:
#   EXPO_PUBLIC_API_URL=http://10.0.2.2:3000
# Development - Physical Device (same WiFi):
#   EXPO_PUBLIC_API_URL=http://YOUR_COMPUTER_IP:3000
# Production:
#   EXPO_PUBLIC_API_URL=https://www.buttergolf.com
EXPO_PUBLIC_API_URL=http://localhost:3000

# Database
DATABASE_URL=
