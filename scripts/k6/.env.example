# ButterGolf k6 suite environment
# Source this file or export these values before running k6.

# Required for staging runs
K6_BASE_URL=https://your-staging-url.example.com
K6_STAGE=staging
K6_PROFILE=smoke

# Must match apps/web MOBILE_SESSION_SECRET. If unset, the app falls back to STRIPE_SECRET_KEY slice or a dev secret.
K6_MOBILE_SESSION_SECRET=

# Seeded test users from packages/db/prisma/seed.ts. Override for staging-specific Clerk IDs if needed.
K6_BUYER_CLERK_ID=user_emma_clerk_id
K6_BUYER_FIRST_NAME=Emma
K6_BUYER_LAST_NAME=Williams
K6_BUYER_EMAIL=emma.williams@example.com
K6_SELLER_CLERK_ID=user_sarah_clerk_id
K6_SELLER_FIRST_NAME=Sarah
K6_SELLER_LAST_NAME=Johnson
K6_SELLER_EMAIL=sarah.johnson@example.com
K6_SECOND_BUYER_CLERK_ID=user_mike_clerk_id
K6_SECOND_BUYER_FIRST_NAME=Mike
K6_SECOND_BUYER_LAST_NAME=Chen
K6_SECOND_BUYER_EMAIL=mike.chen@example.com

# Optional fixed fixtures. If omitted, setup discovers fixtures through APIs.
K6_PRODUCT_ID=
K6_CONVERSATION_ID=
K6_ORDER_ID=

# Mutating profiles are intentionally opt-in.
K6_ENABLE_WRITES=false
K6_ENABLE_UPLOADS=false
K6_ENABLE_STRIPE=false
K6_ENABLE_SHIPPING=false
K6_ENABLE_WEBHOOKS=false
K6_ALLOW_PRODUCTION_WRITES=false

# Webhook secrets for webhook profile. Prefer staging secrets.
K6_CLERK_WEBHOOK_SECRET=
K6_STRIPE_WEBHOOK_SECRET=
K6_STRIPE_CONNECT_WEBHOOK_SECRET=
K6_SHIPENGINE_WEBHOOK_SECRET=

# Optional tuning
K6_PUBLIC_VUS=20
K6_PROTECTED_VUS=10
K6_WRITE_VUS=2
K6_WEBHOOK_VUS=1
K6_LOAD_DURATION=5m
K6_WRITE_DURATION=3m
K6_WEBHOOK_DURATION=2m
