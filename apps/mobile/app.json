{
  "expo": {
    "name": "Buttergolf",
    "slug": "buttergolf",
    "scheme": "buttergolf",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "experiments": {
      "autolinkingModuleResolution": true
    },
    "splash": {
      "image": "./assets/logo-orange.png",
      "resizeMode": "contain",
      "backgroundColor": "#E25F2F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.buttergolf.app",
      "icon": {
        "light": "./assets/icon.png",
        "dark": "./assets/icon-dark.png"
      },
      "associatedDomains": [
        "applinks:buttergolf.com",
        "applinks:www.buttergolf.com",
        "webcredentials:buttergolf.com",
        "webcredentials:www.buttergolf.com"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.buttergolf.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "buttergolf.com",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "www.buttergolf.com",
              "pathPrefix": "/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "updates": {
      "url": "https://u.expo.dev/2d353b01-94f4-4a97-88fc-545e1faff923"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "2d353b01-94f4-4a97-88fc-545e1faff923"
      }
    },
    "owner": "vortexalchemist",
    "plugins": [
      "expo-dev-client",
      "expo-updates",
      "expo-web-browser",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.buttergolf.app",
          "enableGooglePay": true
        }
      ]
    ]
  }
}
