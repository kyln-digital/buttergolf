{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "dev": "expo start --ios",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:local:build": "eas build --platform ios --local",
    "ios:local:build:auto": "eas build --platform ios --local --non-interactive",
    "ios:local:submit": "sh -c 'IPA_PATH=$(ls -t build-*.ipa 2>/dev/null | head -n 1); if [ -z \"$IPA_PATH\" ]; then IPA_PATH=$(find ~/Library/Developer/Xcode/Archives -name \"*.ipa\" -print 2>/dev/null | tail -n 1); fi; if [ -z \"$IPA_PATH\" ]; then IPA_PATH=$(find . -maxdepth 3 -name \"*.ipa\" -print 2>/dev/null | head -n 1); fi; if [ -z \"$IPA_PATH\" ]; then echo \"No .ipa found. Run local build first.\"; exit 1; fi; echo \"Submitting: $IPA_PATH\"; eas submit --platform ios --non-interactive --path \"$IPA_PATH\"'",
    "ios:local:build-and-submit": "pnpm run ios:local:build && pnpm run ios:local:submit",
    "ios:local:build-and-submit:auto": "pnpm run ios:local:build:auto && pnpm run ios:local:submit",
    "web": "expo start --web",
    "lint": "eslint . --fix",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@buttergolf/app": "workspace:*",
    "@buttergolf/assets": "workspace:*",
    "@buttergolf/config": "workspace:*",
    "@buttergolf/ui": "workspace:*",
    "@clerk/clerk-expo": "catalog:",
    "@expo-google-fonts/urbanist": "^0.4.2",
    "@react-navigation/native": "catalog:",
    "@react-navigation/native-stack": "catalog:",
    "@stripe/stripe-react-native": "catalog:",
    "@tamagui/animations-react-native": "catalog:",
    "@tamagui/card": "catalog:",
    "@tamagui/portal": "catalog:",
    "@tamagui/sheet": "catalog:",
    "@tamagui/toast": "catalog:",
    "burnt": "^0.13.0",
    "expo": "catalog:",
    "expo-auth-session": "catalog:",
    "expo-dev-client": "^6.0.20",
    "expo-font": "catalog:",
    "expo-image-picker": "catalog:",
    "expo-notifications": "catalog:",
    "expo-secure-store": "catalog:",
    "expo-splash-screen": "catalog:",
    "expo-status-bar": "catalog:",
    "expo-updates": "catalog:",
    "expo-web-browser": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-native": "catalog:",
    "react-native-phone-entry": "^0.2.4",
    "react-native-reanimated": "catalog:",
    "react-native-safe-area-context": "catalog:",
    "react-native-screens": "catalog:",
    "react-native-sse": "^1.2.1",
    "react-native-svg": "catalog:",
    "react-native-webview": "catalog:",
    "react-native-worklets": "catalog:",
    "solito": "catalog:",
    "tamagui": "catalog:"
  },
  "devDependencies": {
    "@buttergolf/eslint-config": "workspace:*",
    "@buttergolf/typescript-config": "workspace:*",
    "@tamagui/babel-plugin": "catalog:",
    "@types/react": "catalog:",
    "babel-plugin-module-resolver": "^5.0.0",
    "eslint": "catalog:",
    "eslint-config-expo": "catalog:",
    "react-native-svg-transformer": "^1.5.3",
    "typescript": "catalog:"
  },
  "expo": {
    "install": {
      "exclude": [
        "@stripe/stripe-react-native",
        "@types/react"
      ]
    }
  },
  "private": true
}
